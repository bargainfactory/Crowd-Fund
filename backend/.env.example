# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/crowdfund_africa

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Flutterwave (African payments - CFA, Mobile Money, etc.)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_hash

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Currency Exchange
OPEN_EXCHANGE_RATES_APP_ID=your_open_exchange_rates_app_id
# OR use CurrencyLayer:
CURRENCYLAYER_API_KEY=your_currencylayer_api_key

# Blockchain (Ethereum/Polygon)
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_NETWORK=polygon-mumbai
PRIVATE_KEY=your_deployer_wallet_private_key
CROWDFUND_FACTORY_ADDRESS=0x_deployed_factory_contract_address
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Email (SendGrid or SMTP)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@crowdfundafrica.com
EMAIL_FROM_NAME=CrowdfundAfrica

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Security
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=32_char_aes_256_encryption_key_here
RECAPTCHA_SECRET=your_recaptcha_secret_key

# Platform Config
PLATFORM_FEE_PERCENTAGE=3
BASE_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,EUR,GBP,CAD,AUD,JPY,XOF,XAF,NGN,KES,GHS,ZAR
